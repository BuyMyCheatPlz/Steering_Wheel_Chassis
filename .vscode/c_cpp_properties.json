{
  "configurations": [
    {
      "name": "windows-gcc-x64",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "defines": [
        "USE_HAL_DRIVER",
        "STM32F405xx",
        "ARM_MATH_CM4",
        "__FPU_PRESENT=1",
        "__CC_ARM"
      ],
      "compilerPath": "C:/msys64/ucrt64/bin/gcc.exe",
      "cStandard": "${default}",
      "intelliSenseMode": "windows-gcc-x64",
      "cppStandard": "${default}"
    }
  ],
  "version": 4
}